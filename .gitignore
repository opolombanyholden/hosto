# --- HOSTO-specific ---
# /conception/ contains very heavy binary assets (PSD ~50MB, MP4 ~10MB,
# multi-page PDFs ~20MB). Storing them in Git would bloat the repo
# beyond GitHub's recommended size limit.
#
# Policy: text-based specs (.md, .docx, .html, .txt) are versioned.
# Heavy media is kept out — push to Git LFS or shared drive instead.
/conception/**/*.psd
/conception/**/*.mp4
/conception/**/*.mov
/conception/**/*.pdf
/conception/PRODUITS DÉRIVÉS/HOSTO MWANA/akassi template/
# Large bitmap mockups (kept locally, available on shared drive)
/conception/UI/*.png
/conception/UI/UI_UPDATES/*.png
/conception/PRODUITS DÉRIVÉS/HOSTO MWANA/*.png
/conception/portail.png
# Autogenerated Justinmind prototype — not editable, archived externally
/conception/Prototype - HOSTO/

# Local sync queue / sqlite artifacts (mode local / offline)
/database/database.sqlite
/database/database.sqlite-journal
/storage/local-sync/

# Coverage and analysis reports
/coverage/
/build/
/.phpstan-cache/

# Generated API documentation (regenerated by CI)
/public/api-docs/
